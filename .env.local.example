# ─────────────────────────────────────────────────────────────
#  Configuración de LEXIA
# ─────────────────────────────────────────────────────────────
# 1. Copia este archivo y renómbralo a:  .env.local
# 2. Consigue tu API key en:  https://console.anthropic.com  (Settings → API Keys)
# 3. Pega tu key abajo y guarda
# 4. Reinicia el servidor (Ctrl+C y luego npm run dev)
#
# Sin esta key, el generador funciona en modo plantilla (gratis, instantáneo).
# Con la key, Claude (Opus 4.8) redacta los documentos completos con IA.

ANTHROPIC_API_KEY=sk-ant-...

# Opcional — cambiar el modelo (por defecto: claude-opus-4-8)
# Opciones: claude-opus-4-8 (mejor calidad), claude-sonnet-4-6 (más económico)
# ANTHROPIC_MODEL=claude-opus-4-8
